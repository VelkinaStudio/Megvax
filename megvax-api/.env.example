# ── Database & Cache ─────────────────────────────────
# Railway auto-provisions these as ${{Postgres.DATABASE_URL}} and ${{Redis.REDIS_URL}}
DATABASE_URL=postgresql://user:password@host:5432/megvax
REDIS_URL=rediss://default:password@host:6379

# ── JWT Keys ─────────────────────────────────────────
# Option A: Base64-encoded PEM (production / Railway)
#   Generate: cat keys/private.pem | base64 -w0
#   Set JWT_PRIVATE_KEY and JWT_PUBLIC_KEY as Railway variables
# Option B: File paths (local dev)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Encryption ───────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ── Meta (Facebook) API ──────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:4000/meta/callback

# ── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=noreply@megvax.com

# ── App Config ───────────────────────────────────────
ADMIN_EMAIL=admin@megvax.com
FRONTEND_URL=http://localhost:3000

PORT=4000
NODE_ENV=development
